<?xml version="1.0"?>
<launch>
  <!-- Arguments -->
  <arg name="map" description="Map name (folder name in stack_master/maps/)"/>
  <arg name="extract_centerline" default="true" description="Extract centerline from map"/>
  <arg name="optimize" default="false" description="Run trajectory optimization (student implementation)"/>
  <arg name="reverse" default="false" description="Reverse centerline direction (true=CW, default=CCW)"/>
  <arg name="output_csv" default="centerline.csv" description="Output CSV filename"/>

  <!-- Centerline Extractor Node -->
  <node pkg="planner" exec="centerline_extractor" name="centerline_extractor" output="screen"
        if="$(var extract_centerline)">
    <param name="map_name" value="$(var map)"/>
    <param name="reverse" value="$(var reverse)"/>
    <param name="output_csv" value="$(var output_csv)"/>
  </node>

  <!-- Trajectory Optimizer Node (placeholder) -->
  <node pkg="planner" exec="trajectory_optimizer" name="trajectory_optimizer" output="screen"
        if="$(var optimize)">
    <param name="map_name" value="$(var map)"/>
    <param name="input_csv" value="$(var output_csv)"/>
  </node>

</launch>
