<?xml version="1.0"?>
<launch>
  <!-- Arguments -->
  <arg name="sim"          default="false"        description="Use simulator (true) or real hardware (false)"/>
  <arg name="map"                                 description="Map name (search stack_master/maps/)"/>
  <arg name="mapping"      default="false"        description="Run cartographer SLAM to build a new map (true) or localize on existing map (false)"/>
  <arg name="localization" default="cartographer" description="Localization algorithm: cartographer | pf | gt (gt: sim only, gym_bridge provides TF and odom)"/>

  <!-- Config / path helpers -->
  <let name="maps_dir"                value="$(find-pkg-share stack_master)/maps"/>
  <let name="map_path"                value="$(var maps_dir)/$(var map)/$(var map)"/>
  <let name="cartographer_config_dir" value="$(find-pkg-share stack_master)/config"/>
  <let name="maps_save_dir"           value="$(find-pkg-prefix stack_master)/../../src/creating_autonomous_car/stack_master/maps/$(var map)"/>
  <!-- sim=true  -> mapping_2d_sim.lua (no IMU, use odometry) -->
  <!-- sim=false -> mapping_2d.lua     (no IMU, no odometry)  -->
  <let name="mapping_lua" value="mapping_2d.lua"     unless="$(var sim)"/>
  <let name="mapping_lua" value="mapping_2d_sim.lua" if="$(var sim)"/>

  <!-- ========== LOW LEVEL (Sensors + Joy) ========== -->
  <include file="$(find-pkg-share stack_master)/launch/low_level.launch.xml">
    <arg name="sim" value="$(var sim)"/>
  </include>

  <!-- ========== GYM BRIDGE PARAMETERS ========== -->
  <!-- publish_tf: True ONLY for gt mode. All other modes use their localization algorithm for TF. -->
  <let name="gym_publish_tf" value="true"  if="$(eval '\'$(var localization)\' == \'gt\'')"/>
  <let name="gym_publish_tf" value="false" unless="$(eval '\'$(var localization)\' == \'gt\'')"/>

  <!-- ego_odom_topic:
       gt mode  -> 'car_state/odom' : gym_bridge IS the final localization output
       all else -> 'vesc/odom'      : gym_bridge acts as wheel-like odometry source for EKF -->
  <let name="ego_odom_topic" value="car_state/odom" if="$(eval '\'$(var localization)\' == \'gt\'')"/>
  <let name="ego_odom_topic" value="vesc/odom"      unless="$(eval '\'$(var localization)\' == \'gt\'')"/>

  <!-- ========== SIMULATOR ENVIRONMENT ========== -->
  <!-- gym_bridge: virtual /scan, /vesc/odom (or /car_state/odom for gt), optional TF -->
  <group if="$(var sim)">
    <include file="$(find-pkg-share f1tenth_gym_ros)/launch/gym_bridge_launch.py">
      <arg name="map_yaml_path"  value="$(var map_path).yaml"/>
      <arg name="ego_odom_topic" value="$(var ego_odom_topic)"/>
      <arg name="publish_tf"     value="$(var gym_publish_tf)"/>
    </include>
    <include file="$(find-pkg-share obstacle_publisher)/launch/obstacle_publisher.launch.xml">
      <arg name="map_name" value="$(var map)"/>
    </include>
  </group>

  <!-- ================================================================
       MAPPING MODE
       Cartographer SLAM: builds a new map.
       gym_bridge does NOT publish TF → cartographer must publish_to_tf=true (both sim and real).
       ================================================================ -->
  <group if="$(var mapping)">
    <node pkg="cartographer_ros" exec="cartographer_node" name="cartographer_node" output="screen"
          args="-configuration_directory $(var cartographer_config_dir) -configuration_basename $(var mapping_lua) --ros-args --log-level warn">
      <param name="use_sim_time"  value="false"/>
      <remap from="/imu" to="/vesc/sensors/imu/raw"/>
      <remap from="/odom" to="/vesc/odom"/>
      
    </node>

    <node pkg="cartographer_ros" exec="cartographer_occupancy_grid_node"
          name="cartographer_occupancy_grid_node" output="screen"
          args="-resolution 0.05 -publish_period_sec 1.0">
      <param name="use_sim_time" value="false"/>
      <remap from="/map" to="/map_carto"/>
    </node>

    <node pkg="stack_master" exec="pose_to_odom_node.py" name="pose_to_odom_node" output="screen">
      <param name="use_sim_time" value="false"/>
      <remap from="pose_in"  to="/tracked_pose"/>
      <remap from="odom_out" to="/tracked_pose/odom"/>
    </node>

    <node pkg="robot_localization" exec="ekf_node" name="ekf_localization" output="screen">
      <param from="$(find-pkg-share stack_master)/config/ekf_cartographer.yaml"/>
      <param name="use_sim_time" value="false"/>
      <remap from="odometry/filtered" to="/car_state/odom"/>
    </node>

    <node pkg="stack_master" exec="finish_map.py" name="finish_map_node" output="screen">
      <param name="map_name" value="$(var map)"/>
      <param name="maps_dir" value="$(var maps_save_dir)"/>
    </node>
  </group>

  <!-- ================================================================
       LOCALIZATION MODE
       gt:           sim only — gym_bridge provides car_state/odom + map->base_link TF directly.
                     No additional nodes needed.
       cartographer: map_server + cartographer_localization + pose_to_odom + EKF
                     Works for both sim (gym_bridge → /vesc/odom) and real (VESC → /vesc/odom).
       pf:           map_server + particle_filter + EKF
                     Works for both sim (gym_bridge → /vesc/odom) and real (VESC → /vesc/odom).
       ================================================================ -->
  <group unless="$(var mapping)">

    <!-- Map server: always launched in localization mode (all algorithms including gt need the map) -->
    <!-- cartographer occupancy grid is remapped to /map_carto to avoid conflict with map_server /map -->
    <node pkg="nav2_lifecycle_manager" exec="lifecycle_manager"
          name="lifecycle_manager_localization" output="screen">
      <param name="use_sim_time" value="false"/>
      <param name="autostart"    value="true"/>
      <param name="node_names"   value="['map_server']"/>
    </node>
    <node pkg="nav2_map_server" exec="map_server" name="map_server" output="screen">
      <param name="yaml_filename" value="$(var map_path).yaml"/>
      <param name="topic"         value="map"/>
      <param name="frame_id"      value="map"/>
      <param name="use_sim_time"  value="false"/>
    </node>

    <!-- Cartographer Localization -->
    <group if="$(eval '\'$(var localization)\' == \'cartographer\'')">
      <include file="$(find-pkg-share stack_master)/launch/cartographer_localization.launch.xml">
        <arg name="map" value="$(var map)"/>
      </include>
      <node pkg="stack_master" exec="pose_to_odom_node.py" name="pose_to_odom_node" output="screen">
        <remap from="pose_in"  to="/tracked_pose"/>
        <remap from="odom_out" to="/tracked_pose/odom"/>
      </node>
      <node pkg="robot_localization" exec="ekf_node" name="ekf_localization" output="screen">
        <param from="$(find-pkg-share stack_master)/config/ekf_cartographer.yaml"/>
        <remap from="odometry/filtered" to="/car_state/odom"/>
      </node>
    </group>

    <!-- Particle Filter Localization -->
    <group if="$(eval '\'$(var localization)\' == \'pf\'')">
      <!-- <node pkg="particle_filter" exec="particle_filter" name="particle_filter" output="screen">
        <param from="$(find-pkg-share stack_master)/config/pf.yaml"/>
      </node> -->

      <node pkg="particle_filter" exec="particle_filter"
            name="particle_filter"
            output="screen">
        <param from="$(var find-pkg-share stack_master)/config/pf.yaml)"/>
        <param from="$(var vesc_config)"/>
      </node>

      <node pkg="robot_localization" exec="ekf_node" name="ekf_localization" output="screen">
        <param from="$(find-pkg-share stack_master)/config/ekf_pf.yaml"/>
        <remap from="odometry/filtered" to="/car_state/odom"/>
      </node>
    </group>

    <!-- GT (sim only): gym_bridge provides car_state/odom + map->base_link TF. No extra nodes. -->

  </group>

</launch>
