<?xml version="1.0"?>
<launch>
  <!-- Arguments -->
  <arg name="map" description="Map name to use (same as base_system.launch.xml)"/>
  <arg name="speed_scaler" default="0.3" description="Speed multiplier for dynamic obstacle"/>

  <!-- Include dynamic obstacle publisher launch from simulator -->
  <include file="$(find-pkg-share obstacle_publisher)/launch/obstacle_publisher.launch.xml">
    <arg name="map_name" value="$(var map)"/>
    <arg name="speed_scaler" value="$(var speed_scaler)"/>
  </include>

</launch>
