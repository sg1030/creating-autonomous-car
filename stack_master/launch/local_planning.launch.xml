<launch>
  <!--
    local_planning.launch.xml
    =========================
    MPC kinematic local planner + waypoint_publisher + Pure Pursuit.

    Data flow:
      waypoint_publisher -> /global_waypoints
                         -> mpc_local_planner -> /local_waypoints
                         -> pp_node (subscribes /local_waypoints directly)
                         -> /vesc/high_level/ackermann_cmd

    Run (sim):
      ros2 launch stack_master low_level.launch.xml sim:=true map:=final
      ros2 launch stack_master local_planning.launch.xml map:=final sim:=true

    Run (real car):
      ros2 launch stack_master middle_level.launch.xml map:=final
      ros2 launch stack_master local_planning.launch.xml map:=final
  -->

  <arg name="map"    description="Map name (folder in stack_master/maps/)"/>
  <arg name="sim"    default="false" description="true: sim odom (/vesc/odom); false: real car odom (/car_state/odom)"/>
  <arg name="config" default="$(find-pkg-share stack_master)/config/ppc.yaml"/>
  <arg name="mpc_config"
       default="$(find-pkg-share stack_master)/config/mpc_local_planning.yaml"
       description="YAML file with mpc_local_planner tunable parameters"/>

  <!-- 1. Publish global raceline from stack_master/maps/<map>/global_waypoints.csv -->
  <node pkg="planner" exec="waypoint_publisher" name="waypoint_publisher" output="screen">
    <param name="map_name" value="$(var map)"/>
  </node>

  <!-- 2. MPC local planner -->
  <group if="$(var sim)">
    <node pkg="planner" exec="mpc_local_planner" name="mpc_local_planner" output="screen">
      <param from="$(var mpc_config)"/>
      <param name="odom_topic" value="/vesc/odom"/>
    </node>
  </group>
  <group unless="$(var sim)">
    <node pkg="planner" exec="mpc_local_planner" name="mpc_local_planner" output="screen">
      <param from="$(var mpc_config)"/>
      <param name="odom_topic" value="/car_state/odom"/>
    </node>
  </group>

  <!-- 3. Pure Pursuit. PP subscribes to /local_waypoints directly. -->
  <group if="$(var sim)">
    <node pkg="controller" exec="pp_node" name="pp" output="screen">
      <param from="$(var config)"/>
    </node>
  </group>
  <group unless="$(var sim)">
    <node pkg="controller" exec="pp_node" name="pp" output="screen">
      <param from="$(var config)"/>
      <remap from="/vesc/odom" to="/car_state/odom"/>
    </node>
  </group>

</launch>
