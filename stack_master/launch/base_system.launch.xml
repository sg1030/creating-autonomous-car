<?xml version="1.0"?>
<launch>
  <!-- Main Arguments -->
  <arg name="sim"          default="false"        description="Launch from F110 Simulator (true) or real hardware (false)"/>
  <arg name="map"                                 description="Map name to use for localization (will search stack_master/maps/)"/>
  <arg name="localization" default="cartographer" description="Localization algorithm: cartographer or pf (particle_filter)"/>

  <!-- Config paths -->
  <let name="vesc_config" value="$(find-pkg-share stack_master)/config/vesc_config.yaml"/>
  <let name="sim_config"  value="$(find-pkg-share stack_master)/config/SIM/sim.yaml"/>
  <let name="maps_dir"    value="$(find-pkg-share stack_master)/maps"/>
  <let name="map_path"    value="$(var maps_dir)/$(var map)/$(var map)"/>

  <!-- ========== REAL HARDWARE MODE ========== -->
  <group unless="$(var sim)">
    <!-- Launch all sensors: VESC, LiDAR, IMU, etc. -->
    <include file="$(find-pkg-share stack_master)/launch/low_level.launch.xml">
      <arg name="vesc_config" value="$(var vesc_config)"/>
    </include>
  </group>
    
  <include file="$(find-pkg-share stack_master)/launch/middle_level.launch.xml">
    <arg name="map"          value="$(var map)"/>
    <arg name="sim"          value="$(var sim)"/>
    <arg name="localization" value="$(var localization)"/>
  </include>


  <!-- ========== LOCALIZATION (Real Hardware Only) ========== -->
  <!-- Simulator provides ground truth pose, no localization needed -->
  <group unless="$(var sim)">
    <!-- Cartographer Localization -->
    <group if="$(eval '\'$(var localization)\' == \'cartographer\'')">
      <include file="$(find-pkg-share stack_master)/launch/cartographer_localization.launch.xml">
        <arg name="map" value="$(var map)"/>
      </include>
      <!-- Convert cartographer PoseStamped → Odometry for EKF -->
      <node pkg="stack_master" exec="pose_to_odom_node.py" name="pose_to_odom_node" output="screen">
        <remap from="pose_in"  to="/tracked_pose"/>
        <remap from="odom_out" to="/tracked_pose/odom"/>
      </node>
      <!-- EKF: fuse /vesc/odom (twist) + /tracked_pose/odom (cartographer) → /car_state/odom -->
      <node pkg="robot_localization" exec="ekf_node" name="ekf_localization" output="screen">
        <param from="$(find-pkg-share stack_master)/config/ekf_cartographer.yaml"/>
        <remap from="odometry/filtered" to="/car_state/odom"/>
      </node>
    </group>

    <!-- Particle Filter Localization -->
    <group if="$(eval '\'$(var localization)\' == \'pf\'')">
      <include file="$(find-pkg-share stack_master)/launch/particle_filter.launch.xml">
        <arg name="map" value="$(var map)"/>
      </include>
      <!-- EKF: fuse /vesc/odom (twist) + /pf/pose/odom (particle filter) → /car_state/odom -->
      <node pkg="robot_localization" exec="ekf_node" name="ekf_localization" output="screen">
        <param from="$(find-pkg-share stack_master)/config/ekf_pf.yaml"/>
        <remap from="odometry/filtered" to="/car_state/odom"/>
      </node>
    </group>
  </group>

  <!-- ========== COMMON COMPONENTS ========== -->
  <!-- TF tree: localization provides map->base_link, odometry provides odom->base_link -->
  <!-- map->odom is automatically calculated by tf2 -->

  <!-- Waypoint Publisher: centerline, track bounds, global waypoints (markers + WpntArray) -->
  <node pkg="planner" exec="waypoint_publisher" name="waypoint_publisher" output="screen">
    <param name="map_name" value="$(var map)"/>
  </node>

</launch>
