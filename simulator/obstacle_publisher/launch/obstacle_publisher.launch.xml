<?xml version="1.0"?>
<launch>
  <!-- Arguments -->
  <arg name="map_name" default="f" description="Map name (will search in stack_master/maps/)"/>
  <arg name="enable_dynamic" default="false" description="Enable dynamic obstacle"/>
  <arg name="trajectory_csv" default="centerline.csv" description="CSV file name for obstacle trajectory"/>
  <arg name="speed_scaler" default="1.0" description="Speed multiplier for dynamic obstacle"/>
  <arg name="constant_speed" default="false" description="Use constant speed instead of trajectory speed"/>
  <arg name="starting_s" default="0.0" description="Initial position on centerline (meters)"/>
  <arg name="obstacle_length_m" default="0.65" description="Obstacle length in heading direction (meters)"/>
  <arg name="obstacle_width_m" default="0.35" description="Obstacle width in normal direction (meters)"/>
  <arg name="update_rate" default="20" description="Update rate (Hz)"/>
  <arg name="obstacle_diameter_m" default="0.5" description="Static obstacle diameter (meters)"/>

  <!-- Static Obstacle Manager Node (always active) -->
  <node pkg="obstacle_publisher" exec="static_obstacle_manager" name="static_obstacle_manager" output="screen">
    <param name="obstacle_diameter_m" value="$(var obstacle_diameter_m)"/>
  </node>

  <!-- Dynamic Obstacle Publisher Node (optional) -->
  <node pkg="obstacle_publisher" exec="dynamic_obstacle_publisher" name="dynamic_obstacle_publisher" output="screen"
        if="$(var enable_dynamic)">
    <param name="map_name" value="$(var map_name)"/>
    <param name="trajectory_csv" value="$(var trajectory_csv)"/>
    <param name="speed_scaler" value="$(var speed_scaler)"/>
    <param name="constant_speed" value="$(var constant_speed)"/>
    <param name="starting_s" value="$(var starting_s)"/>
    <param name="obstacle_length_m" value="$(var obstacle_length_m)"/>
    <param name="obstacle_width_m" value="$(var obstacle_width_m)"/>
    <param name="update_rate" value="$(var update_rate)"/>
  </node>

</launch>
